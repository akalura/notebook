{
  "name": "my-node-app",
  "version": "1.0.0",
  "description": "Node application with website server, API server, and CLI utils",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start:website": "npm run start -w packages/website",
    "start:api": "npm run start -w packages/api",
    "utils": "npm run cli -w packages/utils",
    "dev": "concurrently \"npm run start:website\" \"npm run start:api\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
